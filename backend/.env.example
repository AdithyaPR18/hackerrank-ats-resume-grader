# Copy to .env and fill in. The backend reads these from the environment.

# Required: Claude API key (https://console.anthropic.com -> Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the scoring model (defaults to claude-sonnet-4-6).
# RESUME_GRADER_MODEL=claude-sonnet-4-6

# Cloud storage for uploaded resumes (Supabase Storage).
# Create a project at https://supabase.com, make a Storage bucket (e.g. "resumes"),
# then copy your project URL and the SERVICE ROLE key (Settings -> API).
# If these are left blank, copies are saved to a local ./uploads folder instead.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=resumes

# Production: lock the API to your deployed frontend (comma-separated origins).
# Leave as * for local development.
ALLOWED_ORIGINS=*
